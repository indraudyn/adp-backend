generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// [TABEL BARU] Tabel Master untuk Versi/Penerjemah
model Version {
  id        Int      @id @default(autoincrement())
  name      String   @unique // Contoh: "Kisari Mohan Ganguli", "Versi A"
  createdAt DateTime @default(now())

  parwas    Parwa[]  // Relasi: 1 Versi memiliki banyak Parwa
}

model Parwa {
  id        Int      @id @default(autoincrement())
  book      String                                  
  sub_parva String?                                 
  section   String?                                 
  judul     String?                                 
  url       String?                                 
  isi       String   @db.LongText
  isi_id    String   @db.LongText                 
  createdAt DateTime @default(now())              
  status    String   @default("pending")
  userId    Int?

  // [TAMBAHAN] Relasi ke tabel Version
  versionId Int      @default(1)
  version   Version  @relation(fields: [versionId], references: [id])
  
  // Relasi ke tabel User
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  resetOtp       String?        
  resetOtpExpiry DateTime?  
  createdAt DateTime @default(now())    

  conversations Conversation[]
  parwas        Parwa[]
}

model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String   @default("Percakapan Baru")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats     Chat[]
}

model Chat {
  id             Int          @id @default(autoincrement())
  conversationId Int
  message        String       @db.LongText
  role           String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}